# ─── Mealie MCP Server Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Base URL of your Mealie instance (no trailing slash)
# Examples:
#   http://localhost:9000        (local installation)
#   http://192.168.1.100:9000   (local network)
#   https://mealie.yourdomain.com (public instance)
MEALIE_URL=http://localhost:9000

# Required: Mealie API key
# Get this from Mealie: Profile → API Tokens → Create Token
# The token will look like: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
MEALIE_API_KEY=your-mealie-api-key-here

# Optional: Transport mode (default: stdio)
# 'stdio' — communicate over stdin/stdout; use this for Claude Desktop / npx invocations
# 'http'  — start an HTTP server; use this for Docker / remote / network deployments
TRANSPORT=stdio

# Optional: Port for HTTP transport mode (default: 3000)
# Only used when TRANSPORT=http
MCP_PORT=3000
