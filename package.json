{
  "name": "@schaferandrew/mealie-mcp-server",
  "version": "0.1.1",
  "description": "MCP server for integrating Mealie recipe manager with Claude and Vivian",
  "main": "dist/index.js",
  "bin": {
    "mealie-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
